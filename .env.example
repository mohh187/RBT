# Firebase web app configuration.
# 1) Go to https://console.firebase.google.com → create a project (free "Spark" plan is enough to start).
# 2) Add a Web App (</>) → copy the config values below.
# 3) Enable: Authentication (Email/Password), Firestore Database, Storage.
# 4) Copy this file to ".env.local" and fill the values. Vite exposes only VITE_* vars to the client.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: base URL used when generating QR codes (defaults to window.location.origin)
VITE_PUBLIC_BASE_URL=

# Custom domains — the platform apex (used to suggest subdomains: slug.APEX) and
# the CNAME target a venue points its own hostname at (Cloudflare-for-SaaS /
# Firebase ingress). Set both to your real brand domain.
VITE_PLATFORM_APEX=menulink.app
VITE_DOMAIN_CNAME_TARGET=connect.menulink.app
# Optional: extra hostnames treated as the platform itself (comma-separated)
VITE_PLATFORM_HOSTS=

# Optional: Web Push (FCM) — enables notifications even when the app is closed.
# Firebase console → Project settings → Cloud Messaging → Web Push certificates → Generate key pair.
# Requires deploying the Cloud Function in /functions (Blaze plan).
VITE_FIREBASE_VAPID_KEY=

# Optional: AI manager assistant (Google Gemini). Get a key at https://aistudio.google.com/apikey
# NOTE: production Gemini calls go through the geminiProxy Cloud Function (server
# key GEMINI_API_KEY in functions/.env) — this client key is a dev-only fallback.
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.0-flash

# Moyasar PUBLISHABLE key (pk_live_… / pk_test_…) — safe on the client; renders
# the card form. The SECRET key lives server-side in functions/.env.
VITE_MOYASAR_PUBLISHABLE_KEY=
