# Copy this file to ".env.shots" (git-ignored) and fill your real values.
# The capture script reads it at runtime; it is NEVER committed and I never
# read this file. Delete it (or rotate the password) after capturing.

# Login for a venue account that has real data (owner/manager).
SHOTS_EMAIL=you@example.com
SHOTS_PASSWORD=your-password

# Your venue's public menu slug — the part after /m/ in the menu URL.
SHOTS_SLUG=your-slug

# Live site (usually leave as-is).
SHOTS_BASE=https://menu-88996.web.app
