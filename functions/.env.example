# Cloud Functions server secrets. Copy to functions/.env (git-ignored) and fill.
# Firebase v2 functions BAKE these at DEPLOY time — after any change, redeploy
# the affected functions (targeted): firebase deploy --only functions:geminiProxy,functions:paymentWebhook,functions:confirmInvoicePayment

# Google Gemini (server key used by the geminiProxy callable).
GEMINI_API_KEY=

# Moyasar SECRET key (sk_live_… / sk_test_…). NEVER expose on the client.
# Used by paymentWebhook + confirmInvoicePayment to verify payments via the Moyasar API.
MOYASAR_SECRET_KEY=

# A random secret you also set as the webhook "Secret Token" in the Moyasar dashboard.
# The webhook rejects any callback whose secret_token doesn't match this.
MOYASAR_WEBHOOK_SECRET=

# Public base URL of the app (used in email/WhatsApp links: menu, invoice, receipt).
# e.g. https://menu-88996.web.app  or  https://rbt360.sa
PUBLIC_BASE_URL=

# --- Email (Resend) — transactional email: owner welcome, subscription invoice/receipt, staff invite. ---
# Get a key at resend.com and verify a sender domain (SPF/DKIM) for EMAIL_FROM.
RESEND_API_KEY=
EMAIL_FROM=rbt360 <no-reply@YOUR-VERIFIED-DOMAIN>

# --- WhatsApp (Meta Cloud API) — customer order/receipt updates. ---
# Create a Meta Business + WhatsApp Business API sender, then fill these.
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_LANG=ar
# Approved Utility templates (Meta). order_update: {{1}} venue {{2}} order# {{3}} status.
WA_TEMPLATE_ORDER_UPDATE=order_update
# receipt: {{1}} venue {{2}} order# {{3}} total {{4}} invoice-link. Optional — falls back to free-form text.
WA_TEMPLATE_RECEIPT=

# --- Realistic 3D (Meshy image-to-3D) — powers «تحويل واقعي 3D» + the batch converter. ---
# Create an account at meshy.ai -> Settings -> API Keys, paste the key, then:
# firebase deploy --only functions:imageTo3d
MESHY_API_KEY=
